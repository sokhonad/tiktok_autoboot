# ── Clés API ─────────────────────────────────────────────────────────────────
# Copie ce fichier en .env et remplis tes clés

# OpenAI API — platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ElevenLabs TTS
ELEVENLABS_API_KEY=...
# Voice ID FR — ex: EXAVITQu4vr4xnSDxMaL (Sarah), 21m00Tcm4TlvDq8ikWAM (Rachel)
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# TikTok cookies (exportés depuis ton navigateur via extension "Cookie-Editor")
TIKTOK_COOKIES_PATH=cookies.json
